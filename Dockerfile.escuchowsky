FROM python:3.12-slim

WORKDIR /app_escuchowsky

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY .collections_ignore .
COPY app_genres.py .
COPY app_genre_mermaid.py .
COPY entrypoint_escuchowsky.sh .
COPY sops_env.py .

RUN chmod +x entrypoint_escuchowsky.sh

# La DB y rym_genres.json se montan como volumen en runtime
ENV PYTHONUNBUFFERED=1

EXPOSE 5001

# El entrypoint genera el árbol de géneros y luego arranca gunicorn
CMD ["./entrypoint_escuchowsky.sh"]
