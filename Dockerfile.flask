FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py .
COPY sops_env.py .

# La DB se monta como volumen en runtime
ENV PYTHONUNBUFFERED=1

EXPOSE 5001

CMD ["python3", "app.py", "--db", "/app/db/must_hear_rym_new.db", "--host", "0.0.0.0", "--port", "5001"]
